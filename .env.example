# Environment Configuration for QiBo Application
# Copy this file to .env and fill in your production values

# Database Configuration (PostgreSQL)
POSTGRES_USER=qibo_user
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=qibo_db

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password
# Note: Redis required for multi-node scaling (userSockets Map limitation)

# User Socket Registry (for future multi-node scaling)
NODE_ID=node_1  # Unique identifier for this server instance
REDIS_SOCKET_REGISTRY_TTL=3600  # TTL for socket registry entries in seconds
REDIS_SOCKET_REGISTRY_SHADOW=false  # Enable Redis shadow writes (dev-only)

# Server Configuration
NODE_ENV=production
PORT=5000
JWT_SECRET=your_very_secure_jwt_secret_at_least_32_characters_long
CLIENT_ORIGIN=https://your-production-domain.com
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=your_secure_super_admin_password

# Client Configuration
VITE_API_URL=https://your-production-api-domain.com
VITE_SOCKET_URL=https://your-production-api-domain.com

# WebRTC Configuration (STUN/TURN servers)
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Nginx Configuration
SERVER_NAME=your-production-domain.com
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# Development Overrides (uncomment for local dev)
# NODE_ENV=development
# CLIENT_ORIGIN=http://localhost:5175
# VITE_API_URL=http://localhost:5000
# VITE_SOCKET_URL=http://localhost:5000