# ZYMI Server Production Environment
# Copy this file to .env and configure values

# Environment
NODE_ENV=production

# Server
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgres://zymi_user:your_secure_password@your-postgres-host:5432/zymi_db

# Redis (for Socket.io scaling)
REDIS_URL=redis://your-redis-host:6379

# JWT (REQUIRED - generate with: openssl rand -hex 32)
# Minimum 64 characters
JWT_SECRET=replace_this_with_your_64_character_secure_random_secret_here

# JWT Expiration
JWT_EXPIRES_IN=7d

# Client Origin (your production domain)
CLIENT_ORIGIN=https://your-domain.com

# Admin credentials (change these!)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change_to_secure_admin_password